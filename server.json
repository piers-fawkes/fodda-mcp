{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.piers-fawkes/fodda",
  "title": "Fodda Knowledge Graphs",
  "description": "Expert-curated PSFK trend intelligence graphs — Retail, Beauty, Sports and more.",
  "websiteUrl": "https://fodda.ai",
  "icons": [
    {
      "src": "https://ucarecdn.com/6e7893d7-6b14-426b-83bc-574a3f72d6bc/foddafavicon.png",
      "sizes": [
        "any"
      ]
    }
  ],
  "version": "1.7.0",
  "repository": {
    "url": "https://github.com/piers-fawkes/fodda-mcp",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "fodda-mcp",
      "version": "1.7.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "FODDA_API_KEY",
          "description": "Your Fodda API key",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "FODDA_API_URL",
          "description": "Upstream Fodda API URL",
          "isRequired": false,
          "default": "https://api.fodda.ai"
        }
      ]
    }
  ]
}