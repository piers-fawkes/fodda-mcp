# Fodda API Configuration
FODDA_API_URL=https://api.fodda.ai
FODDA_API_KEY=your_api_key_here

# HMAC Signing Secret (shared with Fodda API)
FODDA_MCP_SECRET=your_shared_secret_here

# Enable Streamable HTTP (Default: true)
STREAMABLE_HTTP=true

# Enterprise Tools Sandbox: Comma-separated list of allowed tools (Default: search_graph,get_node,get_evidence,get_neighbors)
ALLOWED_TOOLS=search_graph,get_node,get_evidence,get_neighbors

# Comma-separated list of API keys allowed to use simulation mode in production
INTERNAL_TEST_KEYS=

# Rate limiting: requests per minute per API key (default: 60)
RATE_LIMIT_RPM=60

# Slack Bot Token — posts feedback & frustration alerts to #fodda-sales on PSFK workspace
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Resend API Key — sends feedback emails to piers@fodda.ai
RESEND_API_KEY=re_your_resend_key

# Gemini API Key — used by Waverunner tools (deep_research_topic, read_url)
GEMINI_API_KEY=your_gemini_key

# Internal Service API Key — used by Waverunner agent for internal Fodda graph
# calls to prevent double-billing. The API skips decrementCredits() for this key.
FODDA_INTERNAL_API_KEY=sk_internal_your_service_key
